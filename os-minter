#!/bin/bash
# os-minter — Wrapper untuk os-minter.js (Node.js)
DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$DIR/os-minter.js"

# Auto-install deps if missing
if [ ! -d "$DIR/node_modules" ]; then
    echo "🔧 Installing Node.js dependencies..."
    cd "$DIR" && npm install ethers@6 -q && echo "✅ Done"
fi

exec node "$SCRIPT" "$@"
