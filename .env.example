# =====================================================
# OpenSea Minter Bot — Environment Config
# =====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: Never commit .env to git! It's in .gitignore.
# =====================================================

# Your wallet private key (REQUIRED for minting)
# Get from your wallet (MetaMask, etc.)
# Format: 0x9a3f...c9b8
PRIVATE_KEY=""

# OpenSea auth cookie (REQUIRED for all operations)
# How to get:
#   1. Open https://opensea.io in Chrome/Firefox
#   2. Login and connect your wallet
#   3. F12 → Application (Chrome) / Storage (Firefox)
#   4. Cookies → opensea.io → os2AccessEx
#   5. Copy the Value
# Format: os2AccessEx=xyz...
OS_COOKIE=""

# When set, drops listing will use this persisted query hash
# Leave empty until you capture it from browser DevTools
# DROPS_LIST_HASH=""
